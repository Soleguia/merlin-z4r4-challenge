{
  "plugins": ["stylelint-order"],
  "extends": ["stylelint-config-standard-scss"],
  "rules": {
    "selector-class-pattern": null,
    "color-hex-length": "short",
    "color-function-notation": null,
    "alpha-value-notation": null,
    "media-feature-range-notation": null,
    "scss/at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["tailwind"]
      }
    ],
    "order/properties-order": [
      "content",
      "box-sizing",
      "grid-area",
      "grid-column",
      "grid-row",
      "flex",
      "align-self",
      "flex-grow",
      "flex-shrink",
      "flex-basis",
      "position",
      "inset",
      "top",
      "right",
      "bottom",
      "left",
      "z-index",
      "overflow",
      "display",
      "flex-direction",
      "flex-wrap",
      "justify-content",
      "align-items",
      "grid-template-columns",
      "grid-template-rows",
      "grid-template-areas",
      "gap",
      "margin",
      "margin-block",
      "margin-block-start",
      "margin-block-end",
      "margin-inline",
      "margin-inline-start",
      "margin-inline-end",
      "padding",
      "padding-block",
      "padding-block-start",
      "padding-block-end",
      "padding-inline",
      "padding-inline-start",
      "padding-inline-end",
      "aspect-ratio",
      "width",
      "min-width",
      "max-width",
      "height",
      "min-height",
      "max-height",
      "object-fit",
      "font-family",
      "-webkit-font-smoothing",
      "font-size",
      "font-style",
      "font-weight",
      "line-height",
      "letter-spacing",
      "text-align",
      "text-decoration",
      "text-transform",
      "text-indent",
      "text-overflow",
      "white-space",
      "color",
      "background",
      "background-color",
      "background-image",
      "background-repeat",
      "background-position",
      "background-size",
      "background-attachment",
      "border",
      "border-top",
      "border-right",
      "border-bottom",
      "border-left",
      "border-width",
      "border-style",
      "border-color",
      "border-bottom-color",
      "border-radius",
      "box-shadow",
      "cursor",
      "outline",
      "outline-width",
      "outline-style",
      "outline-color",
      "outline-offset",
      "opacity",
      "filter",
      "transform",
      "transform-origin",
      "transform-style",
      "animation",
      "animation-name",
      "animation-duration",
      "animation-timing-function",
      "animation-delay",
      "animation-iteration-count",
      "animation-direction",
      "animation-fill-mode",
      "animation-play-state",
      "transition"
    ]
  },
  "customSyntax": "postcss-scss"
}